			}
		},
		{
			"description": "Key-value pair with quoted value should be extracted as setting",
			"brick": {
				"vars": ["item", "class", "class=\"%s\""],
				"quoted_indices": []
			},
			"expected": {
				"vars": ["item", "class"],
				"quoted_indices": [],
				"local_settings": {
					"class": "%s"
				}
			}
		},
		{
			"description": "Id formatting in Menu template",
			"brick": {
				"vars": ["item", "id", " id='%s'"],
