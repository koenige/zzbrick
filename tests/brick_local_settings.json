			},
			"expected": {
				"vars": [],
				"quoted_indices": [],
				"local_settings": {
					"description": "This is a longer description with multiple words"
				}
			}
		},
		{
			"description": "Empty vars with in_quotes flag",
			"brick": {
				"vars": [],
				"in_quotes": true,
