			},
			"expected": {
				"vars": ["no_equals", "just", "words"],
				"quoted_indices": [],
				"local_settings": []
			}
		},
		{
			"description": "Quoted string with = inside should not be treated as setting",
			"brick": {
				"vars": ["item", "class", " class='%s'"],
				"in_quotes": true,
