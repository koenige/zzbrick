{
	"variables": ["block"],
	"data": [
		{
			"description": "Simple space-separated tokens",
			"block": "foo bar baz",
			"expected": {
				"vars": ["foo", "bar", "baz"],
				"in_quotes": false,
				"quoted_indices": []
			}
		},
		{
			"description": "Standalone quoted string",
			"block": "foo \"bar baz\" qux",
			"expected": {
				"vars": ["foo", "bar baz", "qux"],
				"in_quotes": true,
				"quoted_indices": {
					"1": true
				}
			}
		},
		{
			"description": "Key-value pair with quoted value (single token)",
			"block": "test=\"this is one token\"",
			"expected": {
				"vars": ["test=\"this is one token\""],
				"in_quotes": false,
				"quoted_indices": []
			}
		},
		{
			"description": "Multiple key-value pairs with quoted values",
			"block": "foo=\"bar\" baz=\"qux test\" hello",
			"expected": {
				"vars": ["foo=\"bar\"", "baz=\"qux test\"", "hello"],
				"in_quotes": false,
				"quoted_indices": []
			}
		},
		{
			"description": "Mixed: regular, quoted, and key-value",
			"block": "regular \"quoted string\" key=\"value here\" another",
			"expected": {
				"vars": ["regular", "quoted string", "key=\"value here\"", "another"],
				"in_quotes": true,
				"quoted_indices": {
					"1": true
				}
			}
		},
		{
			"description": "Escaped quotes inside quoted string",
			"block": "\"test \\\"quote\\\"\"",
			"expected": {
				"vars": ["test \"quote\""],
				"in_quotes": true,
				"quoted_indices": [true]
			}
		},
		{
			"description": "Escaped quotes inside key-value",
			"block": "key=\"value with \\\"quotes\\\"\"",
			"expected": {
				"vars": ["key=\"value with \\\"quotes\\\"\""],
				"in_quotes": false,
				"quoted_indices": []
			}
		},
		{
			"description": "Multiple spaces between tokens",
			"block": "foo    bar     baz",
			"expected": {
				"vars": ["foo", "bar", "baz"],
				"in_quotes": false,
				"quoted_indices": []
			}
		},
		{
			"description": "Single token",
			"block": "single",
			"expected": {
				"vars": ["single"],
				"in_quotes": false,
				"quoted_indices": []
			}
		},
		{
			"description": "Single quoted token",
			"block": "\"single token\"",
			"expected": {
				"vars": ["single token"],
				"in_quotes": true,
				"quoted_indices": [true]
			}
		},
		{
			"description": "Empty quoted string",
			"block": "foo \"\" bar",
			"expected": {
				"vars": ["foo", "", "bar"],
				"in_quotes": true,
				"quoted_indices": {
					"1": true
				}
			}
		},
		{
			"description": "Newline separated (fallback behavior)",
			"block": "line1\nline2\nline3",
			"expected": {
				"vars": ["line1", "line2", "line3"],
				"in_quotes": false,
				"quoted_indices": []
			}
		},
		{
			"description": "Complex real-world example",
			"block": "action=\"forms contacts\" mode=\"edit\" id=\"123\" title=\"My Contact Form\"",
			"expected": {
				"vars": ["action=\"forms contacts\"", "mode=\"edit\"", "id=\"123\"", "title=\"My Contact Form\""],
				"in_quotes": false,
				"quoted_indices": []
			}
		},
		{
			"description": "Leading and trailing whitespace",
			"block": "  foo bar baz  ",
			"expected": {
				"vars": ["foo", "bar", "baz"],
				"in_quotes": false,
				"quoted_indices": []
			}
		},
		{
			"description": "Tab separated",
			"block": "foo\tbar\tbaz",
			"expected": {
				"vars": ["foo", "bar", "baz"],
				"in_quotes": false,
				"quoted_indices": []
			}
		},
		{
			"description": "Quoted string with = inside (not a setting)",
			"block": "item id \" id='%s'\"",
			"expected": {
				"vars": ["item", "id", " id='%s'"],
				"in_quotes": true,
				"quoted_indices": {
					"2": true
				}
			}
		},
		{
			"description": "Key-value pair format (is a setting)",
			"block": "item class class=\"%s\"",
			"expected": {
				"vars": ["item", "class", "class=\"%s\""],
				"in_quotes": false,
				"quoted_indices": []
			}
		},
		{
			"description": "Id formatting in Menu template",
			"block": "item id \" id='%s'\"",
			"expected": {
				"vars": ["item", "id", " id='%s'"],
				"in_quotes": true,
				"quoted_indices": {
					"2": true
				}
			}
		}
	]
}
